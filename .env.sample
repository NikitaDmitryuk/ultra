# Секреты для ultra-bot (Telegram Mini App).
# Скопируйте в .env в корне репозитория (.env в .gitignore).
# На сервере устанавливается в /etc/ultra-relay/bot.env (chmod 600).
#
# Остальное (токен admin API, DSN базы данных) ultra-bot получает
# автоматически из /etc/ultra-relay/environment и spec.json — вручную
# задавать не нужно.

# Токен бота — получить у @BotFather → /newbot
TELEGRAM_BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
