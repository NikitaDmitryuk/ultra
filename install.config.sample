# Скопируйте в install.config в корне репозитория (install.config в .gitignore).
# make install — без вопросов; make relay-logs / make verify-relay — хосты и ключ из файла.
#
# Подставьте свои BRIDGE/EXIT и путь к ключу; остальное ниже — рабочие значения по умолчанию.

BRIDGE=203.0.113.10
EXIT=203.0.113.11
SSH_USER=root
IDENTITY=/Users/you/.ssh/id_ed25519
PUBLIC_HOST=203.0.113.10

# Публичный inbound (REALITY): пример цели TLS; замените на свой допустимый host:443.
REALITY_DEST=www.microsoft.com:443
REALITY_SNI=www.microsoft.com

# Шаблон HTTP для splithttp (bridge→exit).
PRESET=steamlike

# Маршрутизация на bridge при split_routing: ru_direct — direct для RU/private, остальное на exit;
# blocklist — только geosite_exit_tags на exit (как раньше).
ROUTING_MODE=ru_direct
# Доп. geosite → direct (только если тег есть в geosite.dat; у runetfreedom по умолчанию нет категории ru).
# GEOSITE_DIRECT_TAGS=ru

VLESS_PORT=443
TUNNEL_PORT=8443
LOG_LEVEL=info
GENERATE_EXIT_TLS=y

# Переиспользовать ключи с bridge при переустановке (Reality, tunnel UUID, splithttp).
# Отключает ротацию ключей — существующие клиентские конфиги продолжают работать.
# Закомментируйте только при намеренной смене ключей.
REUSE_BRIDGE_SPEC=y

# При необходимости: DNS/IP для dial к exit (если отличается от EXIT).
# EXIT_DIAL=exit.example.com

# Переопределение hostname/path сегмента splithttp (SAN self-signed и splithttp_tls под host).
# SPLITHTTP_HOST=
# SPLITHTTP_PATH=

# --- Проверка цепочки после установки (нужны локально xray, jq или python3) ---
VERIFY_AFTER_INSTALL=y
VERIFY_IP_URL=https://api.ipify.org
VERIFY_SOCKS_PORT=10808
# VERIFY_USER_UUID=
# После первого GET по умолчанию вызывается split-routing (только зонд exit). Отключить: VERIFY_SPLIT_ROUTING=n.
# VERIFY_SPLIT_ROUTING=n
# VERIFY_PROBE_EXIT_URL=
# VERIFY_PROBE_EXIT_PLAIN_URL=   # ru_direct без EXIT_URL: по умолчанию api.ipify.org (международный → exit)
VERIFY_FAIL_LOG_LINES=400

# Опционально: geosite-теги в blackhole (нужен тег в вашем geosite.dat), например реклама.
# GEOSITE_BLOCK_TAGS=category-ads-all

# --- Выходной IP (Cloudflare WARP на exit) ---
#
# Cloudflare WARP на exit-ноде: меняет IP выхода с датацентра на Cloudflare.
# Устанавливается автоматически при make install.
# WARP_ENABLE=y
# WARP_PORT=40000   # порт SOCKS5 (по умолчанию 40000)
#
# DNS over HTTPS (включён по умолчанию).
# Bridge использует Yandex DoH для .ru/.su и Cloudflare для остального.
# DOH_DISABLE=y   # раскомментируйте, чтобы использовать системный DNS

# --- Параметры протокола (все опции по умолчанию включены или имеют разумные значения) ---
# Фрагментация TLS ClientHello в туннеле bridge→exit.
# По умолчанию включена; раскомментируйте, чтобы отключить:
# FRAGMENT_DISABLE=y
#
# Паддинг каждого splithttp-чанка случайным числом байт.
# По умолчанию "100-1000"; "0" отключает:
# SPLITHTTP_PADDING=100-1000
#
# Ограничить размер каждого POST в туннеле (0 = умолчание Xray ≈1 МБ):
# SPLITHTTP_MAX_CHUNK_KB=64
#
# Пул TLS-отпечатков (fingerprint) для ротации при каждом перезапуске Xray.
# По умолчанию: chrome,firefox,safari,ios,android,randomized.
# REALITY_FINGERPRINTS=chrome,firefox,safari

# --- Telegram Mini App (ultra-bot) ---
# Чтобы развернуть Telegram-бота с веб-интерфейсом администратора:
#   1. Создайте бота через https://t.me/BotFather и получите токен.
#   2. Запишите токен и другие секреты в .env (см. .env.sample).
#   3. Укажите домен, на котором будет доступна Mini App (FQDN; нужен DNS A-запись на bridge).
#      Let's Encrypt сертификат будет выпущен автоматически.
#   4. Установите BOT_ENABLE=y и запустите make install.
#   В конце установки будет выведен токен для регистрации первого администратора.
#
# BOT_ENABLE=y
# BOT_DOMAIN=admin.example.com   # FQDN с DNS A-записью на BRIDGE
# BOT_PORT=8444                       # HTTPS порт Mini App (по умолчанию 8444)
#
# TLS-сертификат получается автоматически через certbot (HTTP-01) при make install.
# Бесплатный поддомен: https://freedns.afraid.org/ — надёжно работает с Let's Encrypt.

# --- База данных PostgreSQL ---
# DB_ENABLE=y запускает автоматическую установку и настройку PostgreSQL:
#   — primary на DB_HOST (по умолчанию: BRIDGE)
#   — streaming replica на DB_REPLICA (по умолчанию: EXIT)
# Хранит пользователей, ключи, статистику трафика (месячный расход).
# Заделы для Telegram-бота: планы, подписки, платежи, сессии, очередь уведомлений.
#
DB_ENABLE=y
# DB_HOST=          # хост для PostgreSQL primary; пусто = BRIDGE (база на bridge-хосте)
# DB_REPLICA=       # хост для streaming replica;  пусто = EXIT  (реплика на exit-хосте)
# DB_SSH_USER=      # SSH-пользователь для DB-хостов; пусто = SSH_USER
# DB_NAME=ultra_db
# DB_USER=ultra

# --- Прочее (по умолчанию можно не трогать) ---
# Geo на bridge при установке (скачивание с GitHub): по умолчанию выполняется по SSH.
# SKIP_GEO_DOWNLOAD=y — не качать (положите geoip.dat и geosite.dat сами в geo_assets_dir).
# Синоним устаревшего имени: SKIP_RUNETFREEDOM_GEO=y
# GEO_RELEASE_TAG=202603220955 — зафиксировать тег релиза вместо latest.

# Жёсткая проверка SSH host key (нужен заранее заполненный known_hosts):
# export ULTRA_INSTALL_SSH_STRICT_HOST_KEY=yes
