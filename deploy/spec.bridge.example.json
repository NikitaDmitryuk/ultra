{
  "schema_version": 1,
  "tunnel_tls_provision": "user_provided",
  "role": "bridge",
  "mimic_preset": "apijson",
  "users_path": "/etc/ultra-relay/users.json",
  "listen_address": "0.0.0.0",
  "vless_port": 443,
  "admin_listen": "127.0.0.1:8443",
  "public_host": "YOUR_BRIDGE_HOSTNAME_OR_IP",
  "dev_mode": false,
  "reality": {
    "dest": "PUBLIC_TLS_HANDSHAKE_HOST:443",
    "server_names": ["PUBLIC_TLS_HANDSHAKE_HOST"],
    "private_key": "GENERATE_WITH_xray_x25519",
    "short_ids": [""],
    "public_key": "CORRESPONDING_PUBLIC_KEY_FOR_CLIENTS",
    "fingerprint": "chrome",
    "spider_x": "/"
  },
  "exit": {
    "address": "EXIT_PUBLIC_HOST",
    "port": 443,
    "tunnel_uuid": "SHARED_TUNNEL_UUID_BRIDGE_AND_EXIT"
  },
  "splithttp_path": "/api/v1/subscription",
  "splithttp_host": "splithttp.invalid",
  "splithttp_tls": {
    "server_name": "splithttp.invalid",
    "alpn": ["h2"],
    "fingerprint": "chrome"
  },
  "exit_cert": {},

  "geo_assets_dir": "/etc/ultra-relay/geo",
  "routing_mode": "blocklist",
  "geosite_exit_tags": ["ru-blocked-all"],
  "geoip_exit_tags": [],
  "domain_exit": [],
  "domain_direct": [],

  "xray_wire": {},

  "socks5": {
    "enabled": false,
    "port": 1080,
    "username": "homelab",
    "password": "CHANGE_ME"
  }
}
